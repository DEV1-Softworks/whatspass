# -------------------------------------------------------
# Whatspass — Environment Variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# ----------------------------------------------------------
# Required — Meta WhatsApp Business Cloud API credentials
# ----------------------------------------------------------

# The Phone Number ID from your Meta for Developers dashboard.
# Found at: Meta App > WhatsApp > API Setup > Phone Number ID
# Must be numeric (e.g. 123456789012345)
WHATSPASS_PHONE_NUMBER_ID=

# Permanent System User token or temporary access token.
# Generate one from the Meta Business Manager.
WHATSPASS_ACCESS_TOKEN=

# ----------------------------------------------------------
# Optional — API settings (defaults shown)
# ----------------------------------------------------------

# Meta Graph API version to target.
WHATSPASS_API_VERSION=v19.0

# Base URL of the Meta Graph API. Override only for testing.
# Must start with https://
WHATSPASS_BASE_URL=https://graph.facebook.com

# ----------------------------------------------------------
# Optional — OTP message settings (defaults shown)
# ----------------------------------------------------------

# Name of your pre-approved WhatsApp Message Template.
# Must match exactly what is approved in Meta Business Manager.
WHATSPASS_TEMPLATE_NAME=otp_authentication

# BCP-47 language code for the OTP template.
# Examples: en_US, es_ES, pt_BR, fr_FR
WHATSPASS_LANGUAGE_CODE=en_US

# Number of characters in the generated OTP. Must be 4–12.
WHATSPASS_OTP_LENGTH=6

# OTP validity window in seconds. Minimum 60.
# The library does not store OTPs — enforce expiry in your app.
WHATSPASS_OTP_EXPIRY=300

# Set to true to generate alphanumeric OTPs (e.g. "4aB9Qz")
# instead of numeric-only (e.g. "483920").
WHATSPASS_ALPHANUMERIC_OTP=false
